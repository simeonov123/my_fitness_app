<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-03-12-02-link-client-account-user" author="codex">
        <addColumn tableName="clients">
            <column name="account_user_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="clients"
                                 baseColumnNames="account_user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_clients_account_user_id"/>

        <addUniqueConstraint tableName="clients"
                             columnNames="account_user_id"
                             constraintName="uk_clients_account_user_id"/>
    </changeSet>
</databaseChangeLog>
