<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2025-06-08-create-workout-folders" author="codex">
        <createTable tableName="workout_folders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_workout_folders"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sequence_order" type="INT"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="workout_folders"
                                 baseColumnNames="trainer_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_workout_folders_trainer"/>
    </changeSet>

    <changeSet id="2025-06-08-link-workout-templates-to-folders" author="codex">
        <addColumn tableName="workout_templates">
            <column name="folder_id" type="BIGINT"/>
            <column name="sequence_order" type="INT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="workout_templates"
                                 baseColumnNames="folder_id"
                                 referencedTableName="workout_folders"
                                 referencedColumnNames="id"
                                 constraintName="fk_workout_templates_folder"/>
    </changeSet>
</databaseChangeLog>
