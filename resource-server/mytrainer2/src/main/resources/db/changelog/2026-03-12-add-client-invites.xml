<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-03-12-01-create-client-invites" author="codex">
        <createTable tableName="client_invites">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_client_invites"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="invite_token" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="accepted_at" type="DATETIME"/>
            <column name="accepted_by_user_id" type="VARCHAR(36)"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="client_invites"
                                 baseColumnNames="trainer_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_client_invites_trainer"/>

        <addForeignKeyConstraint baseTableName="client_invites"
                                 baseColumnNames="client_id"
                                 referencedTableName="clients"
                                 referencedColumnNames="id"
                                 constraintName="fk_client_invites_client"/>

        <addUniqueConstraint tableName="client_invites"
                             columnNames="invite_token"
                             constraintName="uk_client_invites_token"/>

        <createIndex tableName="client_invites" indexName="idx_client_invites_trainer">
            <column name="trainer_id"/>
        </createIndex>

        <createIndex tableName="client_invites" indexName="idx_client_invites_client">
            <column name="client_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
