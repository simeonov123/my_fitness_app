<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="2025-06-11-add-muscle-groups" author="codex">
        <createTable tableName="muscle_groups">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trainer_id" type="BIGINT"/>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_custom" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="muscle_groups"
                                 baseColumnNames="trainer_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_muscle_groups_trainer"/>

        <createTable tableName="exercise_muscle_groups">
            <column name="exercise_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="muscle_group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="exercise_muscle_groups"
                       columnNames="exercise_id,muscle_group_id"
                       constraintName="pk_exercise_muscle_groups"/>

        <addForeignKeyConstraint baseTableName="exercise_muscle_groups"
                                 baseColumnNames="exercise_id"
                                 referencedTableName="exercises"
                                 referencedColumnNames="id"
                                 constraintName="fk_exercise_muscle_groups_exercise"/>

        <addForeignKeyConstraint baseTableName="exercise_muscle_groups"
                                 baseColumnNames="muscle_group_id"
                                 referencedTableName="muscle_groups"
                                 referencedColumnNames="id"
                                 constraintName="fk_exercise_muscle_groups_group"/>

        <insert tableName="muscle_groups">
            <column name="name" value="Chest"/>
            <column name="is_custom" valueBoolean="false"/>
        </insert>
        <insert tableName="muscle_groups">
            <column name="name" value="Upper Back"/>
            <column name="is_custom" valueBoolean="false"/>
        </insert>
        <insert tableName="muscle_groups">
