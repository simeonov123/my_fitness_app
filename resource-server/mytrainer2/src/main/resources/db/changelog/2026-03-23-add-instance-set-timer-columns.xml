<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-03-23-add-instance-set-timer-columns" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="workout_instance_exercise_has_sets"
                              columnName="stopwatch_started_at_ms"/>
            </not>
        </preConditions>
        <addColumn tableName="workout_instance_exercise_has_sets">
            <column name="stopwatch_started_at_ms" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="2026-03-23-add-instance-set-rest-started-column" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="workout_instance_exercise_has_sets"
                              columnName="rest_started_at_ms"/>
            </not>
        </preConditions>
        <addColumn tableName="workout_instance_exercise_has_sets">
            <column name="rest_started_at_ms" type="BIGINT"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
