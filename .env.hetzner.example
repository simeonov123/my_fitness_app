# Copy to `.env` on the Hetzner server and replace the example values.

# ---- App branding ----
APP_TITLE=MVFitness

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=myfitness
MYSQL_USER=fitness_user
MYSQL_PASSWORD=change-me-app-db
MYSQL_HOST_PORT=127.0.0.1:3307

# ---- Keycloak DB / admin ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak_user
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_HOST_PORT=127.0.0.1:8081
KEYCLOAK_PUBLIC_HOSTNAME=mvfitness.auth.vinkel.org

# ---- Spring resource server ----
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/myfitness?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_unicode_ci
SPRING_DATASOURCE_USERNAME=fitness_user
SPRING_DATASOURCE_PASSWORD=change-me-app-db
RESOURCE_SERVER_HOST_PORT=127.0.0.1:8080

# ---- Public / internal auth URLs ----
KEYCLOAK_INTERNAL_REALM_URL=http://keycloak:8081/realms/myrealm
KEYCLOAK_ISSUER_URI=https://mvfitness.auth.vinkel.org/realms/myrealm
KEYCLOAK_JWK_SET_URI=http://keycloak:8081/realms/myrealm/protocol/openid-connect/certs
KEYCLOAK_ALLOWED_ISSUERS=https://mvfitness.auth.vinkel.org/realms/myrealm

# ---- Invite links ----
APP_CLIENT_INVITE_BASE_URL=mytrainer://invite/client
APP_CLIENT_WEB_INVITE_BASE_URL=https://mvfitness.vinkel.org/onboard/client

# ---- Public frontend build values ----
PUBLIC_API_BASE_URL=https://mvfitness.vinkel.org/api
PUBLIC_KEYCLOAK_REALM_URL=https://mvfitness.auth.vinkel.org/realms/myrealm
PUBLIC_KEYCLOAK_LOGOUT_URL=https://mvfitness.auth.vinkel.org/realms/myrealm/protocol/openid-connect/logout
OIDC_CLIENT_ID=mytrainer2client
MOBILE_REDIRECT_URI=com.mvfitness.mytrainer2client://oauthredirect
MOBILE_POST_LOGOUT_REDIRECT_URI=com.mvfitness.mytrainer2client://logoutredirect

# ---- Frontend / utility ports ----
FLUTTER_HOST_PORT=127.0.0.1:80
ADMINER_HOST_PORT=127.0.0.1:8082
