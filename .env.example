# Copy this file to `.env` for local Docker testing.
# `.env` is gitignored.

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=myfitness
MYSQL_USER=fitness_user
MYSQL_PASSWORD=userpass
MYSQL_HOST_PORT=3307

# ---- Keycloak DB / admin ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpass
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak_user
KEYCLOAK_DB_PASSWORD=keycloakpass
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_HOST_PORT=8081

# ---- Spring resource server ----
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/myfitness
SPRING_DATASOURCE_USERNAME=fitness_user
SPRING_DATASOURCE_PASSWORD=userpass
RESOURCE_SERVER_HOST_PORT=8080
RESOURCE_SERVER_DEBUG_PORT=5005

# ---- Public / internal auth URLs ----
DEV_LAN_HOST=localhost
KEYCLOAK_INTERNAL_REALM_URL=http://keycloak:8081/realms/myrealm
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/myrealm
KEYCLOAK_JWK_SET_URI=http://keycloak:8081/realms/myrealm/protocol/openid-connect/certs
KEYCLOAK_ALLOWED_ISSUERS=http://localhost:8081/realms/myrealm,http://10.0.2.2:8081/realms/myrealm

# ---- Invite links ----
APP_CLIENT_INVITE_BASE_URL=mytrainer://invite/client
APP_CLIENT_WEB_INVITE_BASE_URL=http://localhost:3000/onboard/client

# ---- Frontend / utility ports ----
FLUTTER_HOST_PORT=80
ADMINER_HOST_PORT=8082
